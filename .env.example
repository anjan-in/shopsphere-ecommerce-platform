# ==============================================================================
# SHOPSPHERE ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to a new file named '.env' and fill in your actual credentials.
# DO NOT commit the '.env' file to Git!
# ==============================================================================

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
VITE_FIREBASE_PROJECT_ID=shopsphere-production
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Optional: Google Analytics Measurement ID (if tracking client-side events explicitly)
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# Application Settings
VITE_APP_ENV=development
VITE_APP_API_URL=http://localhost:5173